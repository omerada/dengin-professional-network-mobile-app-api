# Meslektaş Backend - Local Development Environment
# AWS S3 + CloudFront (Production değerleri - local test için)

# AWS Credentials (IAM User credentials for local development)
AWS_ACCESS_KEY_ID=your-iam-access-key
AWS_SECRET_ACCESS_KEY=your-iam-secret-key
AWS_REGION=eu-central-1

# AWS S3 & CloudFront (Profile Images)
AWS_S3_BUCKET=meslektas-prod
AWS_CLOUDFRONT_DOMAIN=daw1sj0p0yrom.cloudfront.net

# Note: Local development uses dev profile with LocalStack by default
# Add these variables only if you want to test with real AWS services locally
