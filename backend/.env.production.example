# Dengin Backend - Production Environment Variables
# Copy this file to .env.production and fill in the values

# Database
DATABASE_URL=jdbc:postgresql://your-rds-endpoint:5432/dengin_prod
DATABASE_USERNAME=dengin_user
DATABASE_PASSWORD=your-secure-password-here

# Redis
REDIS_HOST=your-elasticache-endpoint
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# JWT
JWT_SECRET=your-super-secret-jwt-key-minimum-512-bits-please-change-this

# AWS Credentials (use IAM role in production, these are fallbacks)
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=eu-central-1

# AWS S3 & CloudFront (Profile Images)
AWS_S3_BUCKET=dengin-prod
AWS_CLOUDFRONT_DOMAIN=daw1sj0p0yrom.cloudfront.net

# AWS Rekognition (AI Verification)
AWS_REKOGNITION_BUCKET=dengin-verifications

# OAuth2 - Google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OAuth2 - Instagram
INSTAGRAM_CLIENT_ID=your-instagram-client-id
INSTAGRAM_CLIENT_SECRET=your-instagram-client-secret

# Email - Mailgun
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=mg.dengin.com
MAILGUN_SENDER_EMAIL=noreply@dengin.com
MAILGUN_SENDER_NAME=Dengin
MAILGUN_ENABLED=true
MAILGUN_BASE_URL=https://api.eu.mailgun.net/v3

# Firebase Push Notifications
FIREBASE_ENABLED=true
FIREBASE_PROJECT_ID=dengin-prod
FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"dengin-prod",...}
