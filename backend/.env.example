# Dengin Backend Environment Variables
# Copy this file to .env and fill in your actual values

# ===========================
# Application Settings
# ===========================
APP_NAME=Dengin
APP_VERSION=1.0.0
APP_FRONTEND_URL=https://your-domain.com

# ===========================
# Database Configuration
# ===========================
# Development
DATABASE_URL=jdbc:postgresql://localhost:5433/dengin_dev
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# Production (uncomment for prod)
# DATABASE_URL=jdbc:postgresql://your-prod-host:5432/dengin_prod
# DATABASE_USERNAME=dengin_user
# DATABASE_PASSWORD=your-secure-password

# ===========================
# Redis Configuration
# ===========================
# Development
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=

# Production (uncomment for prod)
# REDIS_HOST=your-redis-host
# REDIS_PORT=6379
# REDIS_PASSWORD=your-redis-password
# REDIS_CLUSTER_NODES=redis-node1:6379,redis-node2:6379,redis-node3:6379

# ===========================
# JWT Security
# ===========================
JWT_SECRET=dengin-super-secret-key-change-in-production-please-use-env-variable-minimum-512-bits
JWT_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=604800000

# ===========================
# CORS Configuration
# ===========================
# NOT: Development için dinamik IP'ler scripts/get-local-ip.js tarafından otomatik eklenir
# Production için gerçek domain'lerinizi ekleyin
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://10.0.2.2:8080,http://localhost:3000,http://localhost:19006,http://localhost:8081,http://10.0.2.2:8081,http://10.0.2.2:19006,dengin://

# ===========================
# AWS Configuration
# ===========================
# Development (LocalStack)
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=eu-central-1
AWS_ENDPOINT=http://localhost:4566

# Production (uncomment for prod)
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_REGION=eu-west-1
# AWS_ENDPOINT=

# S3 Configuration
AWS_S3_BUCKET=dengin-dev
# AWS_S3_BUCKET=dengin-production (for prod)
AWS_S3_PRESIGNED_URL_EXPIRATION=15

# IMPORTANT: For mobile device access to LocalStack
# Set this to your machine's local network IP address (use ipconfig to find it)
# Android emulator cannot access localhost directly
# Find your IP: ipconfig (Windows) or ifconfig (Mac/Linux)
# Set this to your machine's local IP (run: node scripts/get-local-ip.js)
AWS_S3_PRESIGNED_URL_HOST=http://YOUR_LOCAL_IP:4566

# Rekognition Configuration
AWS_REKOGNITION_BUCKET=dengin-verifications
AWS_REKOGNITION_FACE_MATCH_THRESHOLD=80.0
AWS_REKOGNITION_MIN_CONFIDENCE=70.0

# SES Configuration (Production only)
SES_FROM_EMAIL=noreply@dengin.com
SES_REPLY_TO=support@dengin.com

# ===========================
# Email Configuration (Mailgun)
# ===========================
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=your-mailgun-domain.mailgun.org
MAILGUN_SENDER_EMAIL=noreply@your-domain.com
MAILGUN_SENDER_NAME=Dengin
MAILGUN_ENABLED=true
MAILGUN_BASE_URL=https://api.mailgun.net

# ===========================
# Firebase Configuration (Push Notifications)
# ===========================
FIREBASE_ENABLED=true
FIREBASE_PROJECT_ID=your-firebase-project-id
# Download your Firebase service account JSON from Firebase Console:
# Project Settings > Service Accounts > Generate new private key
# Then paste the entire JSON content below (single line, escaped)
FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"your-firebase-project-id","private_key_id":"your-private-key-id","private_key":"-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk@your-project.iam.gserviceaccount.com","client_id":"your-client-id","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/your-service-account","universe_domain":"googleapis.com"}

# ===========================
# OAuth2 Configuration
# =========================== 
# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_OAUTH_CLIENT_ID_IOS=your-google-ios-client-id
GOOGLE_OAUTH_CLIENT_ID_ANDROID=your-google-android-client-id
GOOGLE_OAUTH_CLIENT_ID_WEB=your-google-web-client-id

# Instagram OAuth
FACEBOOK_CLIENT_ID=your-instagram-client-id
FACEBOOK_CLIENT_SECRET=your-instagram-client-secret

# Apple OAuth
APPLE_OAUTH_CLIENT_ID=your-apple-client-id
APPLE_OAUTH_TEAM_ID=your-apple-team-id

# ===========================
# Storage Configuration
# ===========================
STORAGE_TYPE=local
STORAGE_LOCAL_UPLOAD_DIR=./uploads

# Production (uncomment for prod)
# STORAGE_TYPE=s3

# ===========================
# KVKK / Data Protection
# ===========================
KVKK_MANUAL_REVIEW_RETENTION_DAYS=7

# ===========================
# Logging & Monitoring
# ===========================
APP_LOGGING_REQUESTS_ENABLED=true
APP_LOGGING_REQUESTS_INCLUDE_QUERY_STRING=true

# Sentry (Production)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
# SENTRY_ENVIRONMENT=production (for prod)

# CloudWatch (Production)
CLOUDWATCH_ENABLED=false

# ===========================
# Rate Limiting (Production)
# ===========================
RATE_LIMITING_ENABLED=true
RATE_LIMITING_REQUESTS_PER_MINUTE=60
RATE_LIMITING_BURST_CAPACITY=100

# ===========================
# Health Check Configuration
# ===========================
APP_HEALTH_S3_ENABLED=true
APP_HEALTH_S3_TIMEOUT=5000

# ===========================
# Server Configuration
# ===========================
SERVER_PORT=8080
