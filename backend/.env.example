# ===========================
# OAuth2 Configuration
# =========================== 
# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_OAUTH_CLIENT_ID_IOS=your-google-ios-client-id
GOOGLE_OAUTH_CLIENT_ID_ANDROID=your-google-android-client-id
GOOGLE_OAUTH_CLIENT_ID_WEB=your-google-web-client-id

# Instagram OAuth
FACEBOOK_CLIENT_ID=your-instagram-client-id
FACEBOOK_CLIENT_SECRET=your-instagram-client-secret

# Apple OAuth
APPLE_OAUTH_CLIENT_ID=your-apple-client-id
APPLE_OAUTH_TEAM_ID=your-apple-team-id

# ===========================
# Storage Configuration
# ===========================
STORAGE_TYPE=local
STORAGE_LOCAL_UPLOAD_DIR=./uploads

# Production (uncomment for prod)
# STORAGE_TYPE=s3

# ===========================
# KVKK / Data Protection
# ===========================
KVKK_MANUAL_REVIEW_RETENTION_DAYS=7

# ===========================
# Logging & Monitoring
# ===========================
APP_LOGGING_REQUESTS_ENABLED=true
APP_LOGGING_REQUESTS_INCLUDE_QUERY_STRING=true

# Sentry (Production)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
# SENTRY_ENVIRONMENT=production (for prod)

# CloudWatch (Production)
CLOUDWATCH_ENABLED=false

# ===========================
# Rate Limiting (Production)
# ===========================
RATE_LIMITING_ENABLED=true
RATE_LIMITING_REQUESTS_PER_MINUTE=60
RATE_LIMITING_BURST_CAPACITY=100

# ===========================
# Health Check Configuration
# ===========================
APP_HEALTH_S3_ENABLED=true
APP_HEALTH_S3_TIMEOUT=5000

# ===========================
# Server Configuration
# ===========================
SERVER_PORT=8080
