# Meslektaş Backend Environment Variables
# Copy this file to .env and fill in your actual values

# ===========================
# Application Settings
# ===========================
APP_NAME=Meslektaş
APP_VERSION=1.0.0
APP_FRONTEND_URL=https://meslektas.com

# ===========================
# Database Configuration
# ===========================
# Development
DATABASE_URL=jdbc:postgresql://localhost:5433/meslektas_dev
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# Production (uncomment for prod)
# DATABASE_URL=jdbc:postgresql://your-prod-host:5432/meslektas_prod
# DATABASE_USERNAME=meslektas_user
# DATABASE_PASSWORD=your-secure-password

# ===========================
# Redis Configuration
# ===========================
# Development
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=

# Production (uncomment for prod)
# REDIS_HOST=your-redis-host
# REDIS_PORT=6379
# REDIS_PASSWORD=your-redis-password
# REDIS_CLUSTER_NODES=redis-node1:6379,redis-node2:6379,redis-node3:6379

# ===========================
# JWT Security
# ===========================
JWT_SECRET=meslektas-super-secret-key-change-in-production-please-use-env-variable-minimum-512-bits
JWT_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=604800000

# ===========================
# CORS Configuration
# ===========================
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://10.0.2.2:8080,http://192.168.1.100:8080,http://192.168.1.100:8081,http://localhost:3000,http://localhost:19006,http://localhost:8081,http://10.0.2.2:8081,http://10.0.2.2:19006,meslektas://

# ===========================
# AWS Configuration
# ===========================
# Development (LocalStack)
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=eu-central-1
AWS_ENDPOINT=http://localhost:4566

# Production (uncomment for prod)
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_REGION=eu-west-1
# AWS_ENDPOINT=

# S3 Configuration
AWS_S3_BUCKET=meslektas-dev
# AWS_S3_BUCKET=meslektas-production (for prod)
AWS_S3_PRESIGNED_URL_EXPIRATION=15

# Rekognition Configuration
AWS_REKOGNITION_BUCKET=meslektas-verifications
AWS_REKOGNITION_FACE_MATCH_THRESHOLD=80.0
AWS_REKOGNITION_MIN_CONFIDENCE=70.0

# SES Configuration (Production only)
SES_FROM_EMAIL=noreply@meslektas.com
SES_REPLY_TO=support@meslektas.com

# ===========================
# Email Configuration (Mailgun)
# ===========================
MAILGUN_API_KEY=f4f2c9ad3dc712e1c62bee78eb0cb4ed-235e4bb2-e230b8ba
MAILGUN_DOMAIN=sandboxc2c4d29e981a4a079df29181334217b6.mailgun.org
MAILGUN_SENDER_EMAIL=iletisim@omerada.com
MAILGUN_SENDER_NAME=Meslektaş
MAILGUN_ENABLED=true
MAILGUN_BASE_URL=https://api.mailgun.net

# ===========================
# Firebase Configuration (Push Notifications)
# ===========================
FIREBASE_ENABLED=true
FIREBASE_PROJECT_ID=meslektas
