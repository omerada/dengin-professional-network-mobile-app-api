{
  "name": "meslektas-mobile",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "react-native start",
    "ios": "react-native run-ios",
    "android": "react-native run-android",
    "ios:release": "react-native run-ios --configuration Release",
    "android:release": "cd android && ./gradlew assembleRelease",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest __tests__/unit",
    "test:integration": "jest __tests__/integration",
    "test:e2e": "detox test -c ios.sim.debug",
    "test:e2e:android": "detox test -c android.emu.debug",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json}\"",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf node_modules && rm -rf ios/Pods && npm install && cd ios && pod install"
  },
  "dependencies": {
    "@gorhom/bottom-sheet": "^5.2.7",
    "@hookform/resolvers": "^3.3.2",
    "@notifee/react-native": "^7.8.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "^11.2.1",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/native-stack": "^6.9.17",
    "@react-navigation/stack": "^6.3.20",
    "@shopify/flash-list": "^1.6.3",
    "@stomp/stompjs": "^7.0.0",
    "@tanstack/react-query": "^5.12.2",
    "axios": "^1.6.2",
    "date-fns": "^2.30.0",
    "eventemitter3": "^5.0.1",
    "expo": "^54.0.26",
    "expo-clipboard": "^8.0.7",
    "expo-constants": "~18.0.10",
    "expo-file-system": "^19.0.19",
    "expo-haptics": "~15.0.8",
    "expo-image": "^3.0.10",
    "expo-image-manipulator": "^14.0.7",
    "expo-linear-gradient": "~14.0.2",
    "expo-secure-store": "~15.0.7",
    "lottie-react-native": "~7.3.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.48.2",
    "react-native": "0.81.5",
    "react-native-biometrics": "^3.0.1",
    "react-native-device-info": "^10.12.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-image-picker": "^5.6.1",
    "react-native-image-resizer": "^1.4.5",
    "react-native-keychain": "^8.1.2",
    "react-native-permissions": "^4.0.3",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-vector-icons": "^10.0.0",
    "react-native-vision-camera": "^3.6.12",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "^0.5.1",
    "sockjs-client": "^1.6.1",
    "zod": "^3.22.4",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@babel/core": "^7.23.5",
    "@babel/preset-env": "^7.23.5",
    "@babel/runtime": "^7.23.5",
    "@react-native/babel-preset": "^0.73.18",
    "@react-native/metro-config": "^0.73.2",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.4.1",
    "@types/react": "^19.1.10",
    "@types/react-native": "^0.72.7",
    "@types/react-native-vector-icons": "^6.4.18",
    "@types/sockjs-client": "^1.5.4",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "babel-plugin-module-resolver": "^5.0.0",
    "detox": "^20.14.0",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-native": "^4.1.0",
    "immer": "^11.0.1",
    "jest": "^29.7.0",
    "jest-expo": "^54.0.13",
    "prettier": "^3.1.0",
    "react-native-svg-transformer": "^1.1.0",
    "react-test-renderer": "^19.1.0",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18"
  },
  "resolutions": {
    "@stomp/stompjs": "npm:@stomp/stompjs@^7.0.0"
  }
}
