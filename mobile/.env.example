# ===================================
# Dengin Mobile App - Environment Variables
# ===================================
# NOTE: .env files may not work reliably with Expo Go
# For reliable configuration, use app.json extra field or expo-constants
# ===================================

# API Configuration
# ---------------------------------
# For development with emulator/simulator: Leave empty (will use localhost)
# For development with real device: Set to your machine's local IP
# Example: EXPO_PUBLIC_API_BASE_URL=http://192.168.1.105:8080
#
# Find your machine's IP:
# - Windows: ipconfig (look for IPv4 Address under your network adapter)
# - Mac/Linux: ifconfig or ip addr
EXPO_PUBLIC_API_BASE_URL=

# WebSocket URL (optional, defaults to API_BASE_URL/ws)
EXPO_PUBLIC_WS_URL=

# Firebase Configuration
# ---------------------------------
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Sentry (Error Tracking)
# ---------------------------------
EXPO_PUBLIC_SENTRY_DSN=

# Environment
# ---------------------------------
# Options: development, staging, production
EXPO_PUBLIC_ENVIRONMENT=development

# ===================================
# Development Tips:
# ===================================
# 1. Android Emulator: Uses localhost automatically (converted to 10.0.2.2)
# 2. iOS Simulator: Uses localhost as-is
# 3. Real Device: MUST set EXPO_PUBLIC_API_BASE_URL to your machine's local network IP
# 4. Ensure your backend is running and accessible on the network
# 5. Backend CORS should allow requests from mobile (wildcard * in dev mode)
# ===================================
