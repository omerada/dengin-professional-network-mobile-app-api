# API
# For Android Emulator: Use host machine's IP address (192.168.1.101)
# 10.0.2.2 is Android emulator's special alias for host's localhost
# If 10.0.2.2 doesn't work, use your machine's actual IP
API_BASE_URL=http://192.168.1.102:8080
WS_URL=ws://192.168.1.102:8080/ws

# Firebase (Development)
FIREBASE_API_KEY=your_api_key_here
FIREBASE_AUTH_DOMAIN=meslektas-dev.firebaseapp.com
FIREBASE_PROJECT_ID=meslektas-dev
FIREBASE_STORAGE_BUCKET=meslektas-dev.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123456789:ios:abcd

# Sentry
SENTRY_DSN=

# Environment
ENVIRONMENT=development
